# =============================================================================
# Database
# =============================================================================
# SQLite database path. Relative file paths are resolved from the project root.
DATABASE_URL="file:./prisma/dev.db"

# =============================================================================
# Site
# =============================================================================
# Production origin, for example: https://example.com
SITE_URL=""

# Only needed by browser-rendered examples that require the public site origin.
# Usually keep this identical to SITE_URL.
NEXT_PUBLIC_SITE_URL=""

# Absolute or site-relative default social sharing image URL.
OG_IMAGE_URL=""

# =============================================================================
# Web / API processes
# =============================================================================
# Web listens on 3001. The browser keeps using same-origin /api/* URLs; Next.js
# proxies those requests to this private API address.
API_PORT="3002"
API_HOST="127.0.0.1"
API_INTERNAL_URL="http://127.0.0.1:3002"

# Optional absolute directory used for uploaded images and music. The current
# single-machine default is apps/web/public so existing /images and /music URLs
# remain compatible. Move this to object storage before multi-host deployment.
MEDIA_ROOT=""

# =============================================================================
# Authentication
# =============================================================================
# Required. Use a cryptographically random value of at least 32 characters.
# Example generator: openssl rand -hex 32
JWT_SECRET=""

# =============================================================================
# Trusted proxy and rate limiting
# =============================================================================
# Disabled by default. Enable only when the API receives requests exclusively
# through trusted local infrastructure that overwrites the selected IP header.
TRUST_PROXY="false"
TRUST_PROXY_HEADER="x-real-ip"

# Cloudflare alternative:
# TRUST_PROXY_HEADER="cf-connecting-ip"

# Multi-proxy alternative; the first address is treated as the client address:
# TRUST_PROXY_HEADER="x-forwarded-for"

# Registration country-code auto-detection reads GeoIP headers supplied by the
# deployment platform. Supported headers include CF-IPCountry,
# X-Vercel-IP-Country, CloudFront-Viewer-Country, Fastly-Geo-Country-Code,
# X-AppEngine-Country, and X-Country-Code. With Nginx GeoIP2, forward the
# detected ISO country code as X-Country-Code. No third-party lookup is used.

# =============================================================================
# Initial administrator / database seed
# =============================================================================
ADMIN_USERNAME="admin"
ADMIN_DISPLAY_NAME="管理员"

# Leave empty in development to generate and print a temporary password.
ADMIN_PASSWORD=""

# Destructive production seeding remains disabled unless explicitly set to true.
ALLOW_PRODUCTION_SEED=""

# =============================================================================
# Registration email / SMTP
# =============================================================================
# When SMTP is unconfigured in development, the verification API returns a
# debugCode. Production refuses to send codes until SMTP is configured.
SMTP_HOST=""
SMTP_PORT="465"
SMTP_SECURE="true"
SMTP_STARTTLS=""
SMTP_USER=""
SMTP_PASSWORD=""
SMTP_FROM=""

# Typical STARTTLS configuration:
# SMTP_PORT="587"
# SMTP_SECURE="false"
# SMTP_STARTTLS="true"

# =============================================================================
# Registration SMS gateway
# =============================================================================
# Required when phone registration is offered in production. When these values
# are empty in development, the verification API returns a debugCode; production
# refuses to send SMS codes until the gateway is configured.
#
# The gateway receives an HTTPS POST with JSON fields: to, code, sender,
# purpose, and message. Authorization is sent as Bearer <SMS_API_TOKEN>. Any 2xx
# response is treated as success; other responses are reported as send failures.
SMS_API_URL=""
SMS_API_TOKEN=""
SMS_SENDER="KpBlog"

# =============================================================================
# Obsidian / command-line publishing
# =============================================================================
# Generate the API key from /admin/settings. Store the real value in .env.local.
KPBLOG_API_URL=""
KPBLOG_API_KEY=""

# Optional default: draft or publish. Command-line flags take precedence.
KPBLOG_PUBLISH_MODE=""

# =============================================================================
# Update script / PM2
# =============================================================================
# Process names are defined in ecosystem.config.cjs as blog-web and blog-api.
